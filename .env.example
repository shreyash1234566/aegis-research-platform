# Core app settings
NODE_ENV=development
PORT=3000

# OAuth and session
VITE_APP_ID=
JWT_SECRET=replace-with-long-random-secret
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=
OWNER_OPEN_ID=

# Database
DATABASE_URL=mysql://user:password@host:3306/database

# Forge APIs (storage + LLM)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Model routing
DEFAULT_CHAT_MODEL=gemini-2.5-flash
FALLBACK_CHAT_MODEL=gpt-4.1-mini
BOSS_AGENT_MODEL=deepseek-r1-distill-qwen-32b
DOCUMENT_READER_MODEL=qwen2.5-14b-instruct-1m
SUB_AGENT_MODEL=deepseek-r1-distill-qwen-14b
SYNTHESIS_MODEL=self-rag-13b
CRAG_EVALUATOR_MODEL=t5-large
MULTIMODAL_MODEL=qwen2.5-vl-32b
TRANSCRIPTION_MODEL=whisper-large-v3
EMBEDDING_MODEL=mE5-large-instruct

# Optional frontend analytics injected by client/index.html
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# Optional frontend map integration
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
